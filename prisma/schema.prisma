generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StrategyType {
  WHEEL
  CASH_SECURED_PUT
  COVERED_CALL
  LONG_CALL
  LONG_PUT
  SHORT_CALL
  SHORT_PUT
  STOCK
}

enum TradeStatus {
  OPEN
  PARTIAL
  ASSIGNED
  CLOSED
}

enum TradeEventType {
  SELL_TO_OPEN
  BUY_TO_OPEN
  SELL_TO_CLOSE
  BUY_TO_CLOSE
  PARTIAL_CLOSE
  REOPEN
  ROLL
  ASSIGNMENT
  EXERCISE
  EXPIRATION
  STOCK_BUY
  STOCK_SELL
  DIVIDEND
  NOTE
}

enum OptionType {
  CALL
  PUT
}

enum HoldingStatus {
  OPEN
  CLOSED
}

model User {
  id                 String       @id @default(cuid())
  firebaseUid        String       @unique
  email              String       @unique
  displayName        String?
  avatarUrl          String?
  timezone           String       @default("America/Los_Angeles")
  baseCurrency       String       @default("USD")
  portfolioBaselineValue Decimal   @default(0) @db.Decimal(14, 2)
  portfolioBaselineAt DateTime?
  onboardingComplete Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  trades             Trade[]
  tradeEvents        TradeEvent[]
  holdings           HoldingLot[]
  assignments        Assignment[]
  rolls              Roll[]
  fundingEvents      PortfolioFunding[]
}

model PortfolioFunding {
  id         String   @id @default(cuid())
  userId     String
  amount     Decimal  @db.Decimal(14, 2)
  occurredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Trade {
  id                String        @id @default(cuid())
  userId            String
  ticker            String
  accountLabel      String?
  strategy          StrategyType
  optionType        OptionType?
  thesis            String?
  notes             String?
  tags              String[]      @default([])
  status            TradeStatus   @default(OPEN)
  openedAt          DateTime
  closedAt          DateTime?
  openContractCount Int           @default(0)
  shareExposure     Int           @default(0)
  premiumCollected  Decimal       @db.Decimal(14, 2)
  realizedPnl       Decimal       @db.Decimal(14, 2)
  feesPaid          Decimal       @db.Decimal(14, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  archivedAt        DateTime?
  holdingLotId      String?       @map("holding_lot_id")
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdingLot        HoldingLot?   @relation("CoveredCalls", fields: [holdingLotId], references: [id], onDelete: SetNull)
  events            TradeEvent[]
  holdings          HoldingLot[]

  @@index([userId, status])
  @@index([userId, ticker])
}

model TradeEvent {
  id                String         @id @default(cuid())
  userId            String
  tradeId           String
  type              TradeEventType
  occurredAt        DateTime
  optionType        OptionType?
  contractsDelta    Int?
  sharesDelta       Int?
  strikePrice       Decimal?       @db.Decimal(12, 2)
  expiration        DateTime?
  premium           Decimal?       @db.Decimal(14, 2)
  fees              Decimal?       @db.Decimal(14, 2)
  realizedPnl       Decimal?       @db.Decimal(14, 2)
  underlyingPrice   Decimal?       @db.Decimal(12, 2)
  sharePrice        Decimal?       @db.Decimal(12, 2)
  notes             String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade             Trade          @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  assignmentRecords Assignment[]
  rollChildren      Roll[]         @relation("RollToEvent")
  rollParents       Roll[]         @relation("RollFromEvent")

  @@index([userId, occurredAt])
  @@index([tradeId, occurredAt])
}

model HoldingLot {
  id                String        @id @default(cuid())
  userId            String
  tradeId           String?
  ticker            String
  openedAt          DateTime
  closedAt          DateTime?
  acquiredVia       TradeEventType
  quantity          Int
  remainingQuantity Int
  costBasisPerShare Decimal       @db.Decimal(12, 2)
  realizedPnl       Decimal       @db.Decimal(14, 2)
  status            HoldingStatus @default(OPEN)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  archivedAt        DateTime?
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade             Trade?        @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  coveredCalls      Trade[]       @relation("CoveredCalls")
  assignments       Assignment[]

  @@index([userId, ticker])
  @@index([userId, status])
}

model Assignment {
  id                 String     @id @default(cuid())
  userId             String
  tradeEventId       String
  holdingLotId       String?
  ticker             String
  optionType         OptionType
  strikePrice        Decimal    @db.Decimal(12, 2)
  shareQuantity      Int
  premiumApplied     Decimal    @db.Decimal(14, 2)
  adjustedCostBasis  Decimal    @db.Decimal(12, 2)
  assignedAt         DateTime
  createdAt          DateTime   @default(now())
  event              TradeEvent @relation(fields: [tradeEventId], references: [id], onDelete: Cascade)
  holdingLot         HoldingLot? @relation(fields: [holdingLotId], references: [id], onDelete: SetNull)
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assignedAt])
}

model Roll {
  id            String     @id @default(cuid())
  userId        String
  fromEventId   String
  toEventId     String
  netCredit     Decimal    @db.Decimal(14, 2)
  createdAt     DateTime   @default(now())
  fromEvent     TradeEvent @relation("RollFromEvent", fields: [fromEventId], references: [id], onDelete: Cascade)
  toEvent       TradeEvent @relation("RollToEvent", fields: [toEventId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
